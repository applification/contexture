{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.jsonc",
      "!.sandcastle",
      "!.claude/settings.local.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "security": {
        "noGlobalEval": "error",
        "noDangerouslySetInnerHtml": "error"
      },
      "a11y": {
        "useValidAriaRole": "error",
        "useButtonType": "error",
        "useValidAnchor": "error",
        "noStaticElementInteractions": "error",
        "noSvgWithoutTitle": "error",
        "useKeyWithClickEvents": "error",
        "noLabelWithoutControl": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "noInnerDeclarations": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useNodejsImportProtocol": "error",
        "useImportType": "error",
        "useTemplate": "error",
        "useExponentiationOperator": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "error",
        "noExplicitAny": "error",
        "useIterableCallbackReturn": "error",
        "noTsIgnore": "error"
      },
      "complexity": {
        "noImportantStyles": "error",
        "useLiteralKeys": "error",
        "noUselessContinue": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "css": {
    "linter": {
      "enabled": false
    },
    "formatter": {
      "enabled": false
    },
    "parser": {
      "cssModules": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@contexture/stdlib": "Apps must import runtime types via @contexture/runtime, not @contexture/stdlib. (Escape hatch: @contexture/stdlib/registry is allowed for editor tooling — see packages/stdlib/src/registry.ts.)",
                  "@contexture/stdlib/common": "Use @contexture/runtime/common instead.",
                  "@contexture/stdlib/identity": "Use @contexture/runtime/identity instead.",
                  "@contexture/stdlib/place": "Use @contexture/runtime/place instead.",
                  "@contexture/stdlib/money": "Use @contexture/runtime/money instead.",
                  "@contexture/stdlib/contact": "Use @contexture/runtime/contact instead."
                }
              }
            }
          }
        }
      }
    }
  ]
}
