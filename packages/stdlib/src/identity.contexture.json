{
  "version": "1",
  "metadata": {
    "name": "identity",
    "description": "Names and handles."
  },
  "types": [
    {
      "kind": "object",
      "name": "PersonName",
      "description": "Structured personal name.",
      "fields": [
        { "name": "given", "type": { "kind": "string" } },
        { "name": "family", "type": { "kind": "string" } },
        { "name": "middle", "type": { "kind": "string" }, "optional": true },
        { "name": "suffix", "type": { "kind": "string" }, "optional": true }
      ]
    },
    {
      "kind": "raw",
      "name": "Pronouns",
      "description": "Free-form pronouns string.",
      "zod": "z.string()",
      "jsonSchema": { "type": "string" }
    },
    {
      "kind": "raw",
      "name": "Handle",
      "description": "Social handle: ASCII letters, digits, underscore; 1–30 chars.",
      "zod": "z.string().regex(/^[a-zA-Z0-9_]{1,30}$/)",
      "jsonSchema": { "type": "string", "pattern": "^[a-zA-Z0-9_]{1,30}$" }
    }
  ]
}
