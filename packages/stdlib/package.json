    "./contact": "./src/contact.ts",
    "./ir/*": "./src/*.contexture.json",
    "./registry": "./src/registry.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
