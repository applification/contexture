{
  "name": "@contexture/stdlib",
  "version": "0.0.0",
  "private": true,
  "description": "Internal curated Zod stdlib for Contexture. Not published — the public surface is @contexture/runtime.",
  "type": "module",
  "exports": {
    "./common": "./src/common.ts",
