{
  "name": "contexture",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@contexture/desktop",
    "dev:all": "turbo dev",
    "dev:web": "turbo dev --filter=@contexture/web",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:no-suppressions": "bun scripts/check-no-suppressions.ts",
    "env:scan": "varlock scan",
    "ci": "TURBO_NO_UPDATE_NOTIFIER=1 turbo typecheck test --output-logs=errors-only && biome check . && bun run check:no-suppressions && bun run env:scan",
    "prepare": "husky",
    "sandcastle": "varlock run --path .sandcastle/ -- bun .sandcastle/main.ts",
    "sandcastle:analyze": "bun .sandcastle/analyze.ts",
    "sandcastle:build": "bunx sandcastle docker build-image",
    "cleanup": "bun scripts/cleanup-branches.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "^1.3.13",
    "@varlock/infisical-plugin": "^1.1.0",
    "convex": "1.40.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.7",
    "varlock": "^1.1.0"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.5.5",
    "@anthropic-ai/sdk": "0.95.1",
    "@sindresorhus/slugify": "^3.0.0",
    "zod": "^4.3.6"
  },
  "trustedDependencies": [
    "electron",
    "@biomejs/biome",
    "esbuild"
  ],
  "overrides": {
    "@anthropic-ai/sdk": "0.95.1",
    "@next/env": "npm:@varlock/nextjs-integration@^1.1.0",
    "mermaid": "11.15.0",
    "postcss": "^8.5.14"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
